# =============================================================================
# ShiftMaster Production Configuration
# =============================================================================
# Copy this to .env on the server and update DB credentials

# -----------------------------------------------------------------------------
# Database Configuration — UPDATE THESE FOR YOUR SERVER
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=cpper
DB_PASSWORD=0770
DB_NAME=shiftmaster
DB_SSL_MODE=disable

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENV=production

# -----------------------------------------------------------------------------
# JWT & Security — CHANGE JWT_SECRET IN PRODUCTION!
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_to_a_strong_random_64_char_string_here_now
APP_SECRET_KEY=CHANGE_ME_to_another_strong_random_64_char_string
JWT_ISSUER=shiftmaster-api
JWT_ACCESS_EXPIRE_MIN=60
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# Rate Limiting & Lockout
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MIN=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15
TRUSTED_PROXIES=127.0.0.1,192.168.16.0/24

# -----------------------------------------------------------------------------
# CORS Configuration — Caddy serves on port 80, API on 8080 (internal)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://192.168.16.138,http://192.168.16.138:80,http://localhost
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# -----------------------------------------------------------------------------
# Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_BASE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=pdf,png,jpg,jpeg,doc,docx

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
