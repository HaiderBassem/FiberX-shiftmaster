#
# Production Environment Configuration
# =============================================================================
# Deploy path: /opt/shiftmaster/.env
# Service:     systemctl start shiftmaster
# Proxy:       Caddy → :80 → Go API :8080
# =============================================================================

# =============================================================================
# 🗄️  DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=shift_admin
DB_PASSWORD=0770
DB_NAME=shiftmaster
DB_SSL_MODE=disable

# ── Connection Pool (production-tuned) ───────────────────────────────────────
DB_MAX_OPEN_CONNS=50
DB_MIN_CONNS=10
DB_CONN_MAX_LIFETIME=3600
DB_CONN_MAX_IDLE_TIME=1800
DB_CONNECT_TIMEOUT=10
DB_QUERY_TIMEOUT=30
DB_LONG_QUERY_TIMEOUT=300
DB_HEALTH_CHECK_PERIOD=60
DB_MAX_RETRIES=3
DB_RETRY_INTERVAL_MS=100

# =============================================================================
# 🌐  SERVER CONFIGURATION
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENV=production

# ── HTTP Timeouts (seconds) ──────────────────────────────────────────────────
SERVER_READ_TIMEOUT=60
SERVER_WRITE_TIMEOUT=60
SERVER_IDLE_TIMEOUT=120

# =============================================================================
# 🔐  JWT & SECURITY CONFIGURATION
# =============================================================================
# ⚠️  Use strong, unique secrets (≥ 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=668ce6e49e46273d9e011575128202de52a37efafd8ce19f6ad934551cf54e74
APP_SECRET_KEY=98d7f1b4114718acbc8dc70758fbd02dffc48cff3fb579117eb034441379ed0c
JWT_ISSUER=shiftmaster-api
JWT_ACCESS_EXPIRE_MIN=60
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# ── Rate Limiting & Account Lockout ──────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MIN=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15

# ── Trusted Proxies ─────────────────────────────────────────────────────────
TRUSTED_PROXIES=127.0.0.1,192.168.16.0/24

# =============================================================================
# 🔗  CORS CONFIGURATION
# =============================================================================
# Caddy serves frontend on :80, API is internal on :8080
CORS_ALLOWED_ORIGINS=http://192.168.16.138,http://192.168.16.138:80,http://localhost
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# =============================================================================
# 📁  UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_BASE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=pdf,png,jpg,jpeg,doc,docx

# =============================================================================
# 🔔  PUSH NOTIFICATIONS (VAPID)
# =============================================================================
VAPID_PUBLIC_KEY=BNyt_qwA6kGNoLkxa3RAeWzDSrn99vEyMxr6dyry7VAOlRfew2kBKlbiQ3iY66DQEVhGHW8vmjqBMWLU4sVvpe4
VAPID_PRIVATE_KEY=sGheD9s_IsBr-zTV8mxacOyG1qJKc5o8kBlYtvNpBA8
VAPID_SUBJECT=mailto:support@fiberx.iq

# =============================================================================
# 📋  LOGGING CONFIGURATION
# =============================================================================
# Production: use 'info' to reduce noise; switch to 'debug' for troubleshooting
LOG_LEVEL=info
LOG_FORMAT=json
