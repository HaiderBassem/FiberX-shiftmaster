# =============================================================================
# ShiftMaster Caddy Configuration — Production
# =============================================================================
# Place at: /etc/caddy/Caddyfile  OR  run: caddy run --config /opt/shiftmaster/Caddyfile

http://192.168.16.138:80 {
	# ── Compression ──
	encode gzip zstd

	# ── API Reverse Proxy ──
	handle /api/* {
		reverse_proxy 127.0.0.1:8080
	}

	handle /health {
		reverse_proxy 127.0.0.1:8080
	}

	# ── Serve Frontend Static Files ──
	handle {
		root * /opt/shiftmaster/frontend/dist
		try_files {path} /index.html
		file_server
	}

	# ── Security Headers ──
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}

	# ── Logging ──
	log {
		output file /var/log/caddy/shiftmaster.log
		format json
	}
}
