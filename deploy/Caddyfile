# =============================================================================
# ShiftMaster & KMZ Map Configuration - Production Environment
# =============================================================================

http://192.168.16.138:80 {
	# ── Compression ──
	encode gzip zstd

	# ── API Reverse Proxy → Go Backend ──
	handle /api/* {
		reverse_proxy 127.0.0.1:8080
	}

	# ── Health Check Route ──
	handle /health {
		reverse_proxy 127.0.0.1:8080
	}

	# ── KMZ Map Service (Node.js) ──
	# handle_path strips the "/maps" prefix before forwarding to port 9999
	handle_path /maps/* {
		reverse_proxy localhost:9999
	}

	# ── Frontend Static Files (React) ──
	handle {
		root * /opt/shiftmaster/frontend/dist
		try_files {path} /index.html
		file_server
	}

	# ── Security Headers ──
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}

	# ── Logging ──
	log {
		output file /var/log/caddy/shiftmaster.log
		format json
	}
}
