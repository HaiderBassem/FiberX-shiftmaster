{
	"info": {
		"name": "ShiftMaster API",
		"description": "API Collection for the ShiftMaster scheduling system",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"employee_code\": \"ADMIN001\",\n  \"password\": \"admin123\"\n}"
						}
					}
				},
				{
					"name": "Get My Profile",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"]}
					}
				}
			]
		},
		{
			"name": "2. Shifts (Admin)",
			"item": [
				{
					"name": "Create Shift",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/shifts", "host": ["{{base_url}}"], "path": ["api", "shifts"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"shift_code\": \"MORN-01\",\n  \"name\": \"Morning Shift\",\n  \"start_time\": \"08:00:00\",\n  \"end_time\": \"16:00:00\",\n  \"color_code\": \"#3498db\"\n}"
						}
					}
				},
				{
					"name": "List Shifts",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/shifts", "host": ["{{base_url}}"], "path": ["api", "shifts"]}
					}
				}
			]
		},
		{
			"name": "3. Employees (Admin)",
			"item": [
				{
					"name": "Create Employee",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/employees", "host": ["{{base_url}}"], "path": ["api", "employees"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"employee_code\": \"EMP001\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"gender\": \"male\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+123456789\",\n  \"hire_date\": \"2024-01-01\",\n  \"role\": \"employee\",\n  \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "List Employees",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/employees?status=active", "host": ["{{base_url}}"], "path": ["api", "employees"]}
					}
				}
			]
		},
		{
			"name": "4. Leaves",
			"item": [
				{
					"name": "Request Leave",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/leaves", "host": ["{{base_url}}"], "path": ["api", "leaves"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"leave_type\": \"annual\",\n  \"start_date\": \"2024-05-01\",\n  \"end_date\": \"2024-05-05\",\n  \"reason\": \"Family vacation\"\n}"
						}
					}
				},
				{
					"name": "My Leaves",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/leaves/me", "host": ["{{base_url}}"], "path": ["api", "leaves", "me"]}
					}
				}
			]
		},
		{
			"name": "5. Swaps",
			"item": [
				{
					"name": "Request Swap",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/swaps", "host": ["{{base_url}}"], "path": ["api", "swaps"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"target_employee_id\": \"b32e6065-2244-4860-938b-825bfeb1de9b\",\n  \"shift_date\": \"2024-05-10\",\n  \"reason\": \"Need to attend a doctor appointment\"\n}"
						}
					}
				},
				{
					"name": "My Swap Requests",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/swaps/me", "host": ["{{base_url}}"], "path": ["api", "swaps", "me"]}
					}
				}
			]
		},
		{
			"name": "6. Schedules",
			"item": [
				{
					"name": "Generate Weekly Schedule",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {"raw": "{{base_url}}/api/schedules/generate", "host": ["{{base_url}}"], "path": ["api", "schedules", "generate"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"week_start_date\": \"2024-05-12\"\n}"
						}
					}
				},
				{
					"name": "Get Daily Shifts",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/schedules/daily?date=2024-05-12",
							"host": ["{{base_url}}"],
							"path": ["api", "schedules", "daily"],
							"query": [{"key": "date", "value": "2024-05-12"}]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "jwt_token",
			"value": "paste_your_token_from_login_here"
		}
	]
}
