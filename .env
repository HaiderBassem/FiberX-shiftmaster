#
# Production Environment Configuration
# =============================================================================
# Generated: 2026-05-02
# Module:    shiftmaster-backend
# Stack:     Go 1.26 · Gin · PostgreSQL · Caddy
# =============================================================================

# =============================================================================
# 🗄️  DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# Primary connection parameters for pgx/v5 driver
DB_HOST=localhost
DB_PORT=5432
DB_USER=cpper
DB_PASSWORD=0770
DB_NAME=shiftmaster
DB_SSL_MODE=disable

# ── Connection Pool Tuning ───────────────────────────────────────────────────
# Fine-tune pool behavior for production workloads.
# These values are optional; defaults (shown) are applied if omitted.
#
# DB_MAX_OPEN_CONNS       — Maximum simultaneous open connections (default: 50)
# DB_MIN_CONNS            — Minimum idle connections kept alive   (default: 10)
# DB_CONN_MAX_LIFETIME    — Max lifetime of a connection in sec   (default: 3600)
# DB_CONN_MAX_IDLE_TIME   — Max idle time before closing in sec   (default: 1800)
# DB_CONNECT_TIMEOUT      — Dial timeout in seconds               (default: 10)
# DB_QUERY_TIMEOUT        — Standard query timeout in seconds     (default: 30)
# DB_LONG_QUERY_TIMEOUT   — Long-running query timeout in sec     (default: 300)
# DB_HEALTH_CHECK_PERIOD  — Health-check interval in seconds      (default: 60)
# DB_MAX_RETRIES          — Connection retry attempts              (default: 3)
# DB_RETRY_INTERVAL_MS    — Delay between retries in ms           (default: 100)
# ─────────────────────────────────────────────────────────────────────────────
DB_MAX_OPEN_CONNS=50
DB_MIN_CONNS=10
DB_CONN_MAX_LIFETIME=3600
DB_CONN_MAX_IDLE_TIME=1800
DB_CONNECT_TIMEOUT=10
DB_QUERY_TIMEOUT=30
DB_LONG_QUERY_TIMEOUT=300
DB_HEALTH_CHECK_PERIOD=60
DB_MAX_RETRIES=3
DB_RETRY_INTERVAL_MS=100

# =============================================================================
# 🌐  SERVER CONFIGURATION
# =============================================================================
# The API listens on SERVER_HOST:SERVER_PORT (proxied by Caddy on :80).
# ENV controls behavior: 'development' | 'staging' | 'production'
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENV=production

# ── HTTP Timeouts (seconds) ──────────────────────────────────────────────────
# SERVER_READ_TIMEOUT   — Max time to read the full request   (default: 60)
# SERVER_WRITE_TIMEOUT  — Max time to write the response      (default: 60)
# SERVER_IDLE_TIMEOUT   — Max keep-alive idle time             (default: 120)
# ─────────────────────────────────────────────────────────────────────────────
SERVER_READ_TIMEOUT=60
SERVER_WRITE_TIMEOUT=60
SERVER_IDLE_TIMEOUT=120

# =============================================================================
# 🔐  JWT & SECURITY CONFIGURATION
# =============================================================================
# IMPORTANT: Use strong, unique secrets in production (≥ 32 characters).
JWT_SECRET=668ce6e49e46273d9e011575128202de52a37efafd8ce19f6ad934551cf54e74
APP_SECRET_KEY=98d7f1b4114718acbc8dc70758fbd02dffc48cff3fb579117eb034441379ed0c
JWT_ISSUER=shiftmaster-api
JWT_ACCESS_EXPIRE_MIN=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# ── Rate Limiting & Account Lockout ──────────────────────────────────────────
# RATE_LIMIT_REQUESTS    — Max requests per window   (default: 100)
# RATE_LIMIT_WINDOW_MIN  — Window size in minutes    (default: 15)
# MAX_LOGIN_ATTEMPTS     — Failed logins before lock (default: 5)
# LOCKOUT_DURATION_MIN   — Lockout period in minutes (default: 15)
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MIN=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15

# ── Trusted Proxies ─────────────────────────────────────────────────────────
# Comma-separated IPs or CIDR ranges. Required for accurate client IP detection
# behind Caddy / reverse proxies. Includes local network ranges.
TRUSTED_PROXIES=127.0.0.1,192.168.15.0/24,192.168.16.0/24

# =============================================================================
# 🔗  CORS CONFIGURATION
# =============================================================================
# Allowed origins for cross-origin requests.
# Caddy serves frontend on :80, Vite dev-server on :5173.
CORS_ALLOWED_ORIGINS=http://192.168.16.138,http://192.168.16.138:80,http://192.168.16.138:5173,http://localhost:5173
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# =============================================================================
# 📁  UPLOAD CONFIGURATION
# =============================================================================
# Files are stored under UPLOAD_BASE_PATH with sub-directories:
#   ./uploads/assignments/  — Shift assignment documents
#   ./uploads/profiles/     — Employee profile photos
#   ./uploads/documents/    — General documents
UPLOAD_BASE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=pdf,png,jpg,jpeg,doc,docx

# =============================================================================
# 📋  LOGGING CONFIGURATION
# =============================================================================
# LOG_LEVEL  — Verbosity: 'debug' | 'info' | 'warn' | 'error'
# LOG_FORMAT — Output format: 'json' (structured) | 'text' (human-readable)
LOG_LEVEL=debug
LOG_FORMAT=json
