# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=cpper
DB_PASSWORD=0770
DB_NAME=shiftmaster
DB_SSL_MODE=disable

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENV=production

# -----------------------------------------------------------------------------
# JWT & Security Configuration
# -----------------------------------------------------------------------------
JWT_SECRET=shiftmaster_jwt_secret_key_production_2026_secure_enough_for_deploy
APP_SECRET_KEY=shiftmaster_app_secret_key_production_2026_very_secure_key
JWT_ISSUER=shiftmaster-api
JWT_ACCESS_EXPIRE_MIN=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# Rate Limiting & Lockout
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MIN=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15
# Added your local network range to trusted proxies
TRUSTED_PROXIES=127.0.0.1,192.168.15.0/24,192.168.16.0/24

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Consolidated origins: includes localhost and both potential network IPs
CORS_ALLOWED_ORIGINS=http://192.168.16.138,http://192.168.16.138:80,http://192.168.16.138:5173,http://localhost:5173
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# -----------------------------------------------------------------------------
# Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_BASE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=pdf,png,jpg,jpeg,doc,docx

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=json
