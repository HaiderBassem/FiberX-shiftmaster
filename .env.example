# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=cpper
DB_PASSWORD=0770
DB_NAME=shiftmaster
DB_SSL_MODE=disable

# Connection Pool Settings (Optional overrides)
# DB_MAX_OPEN_CONNS=50
# DB_MIN_CONNS=10
# DB_CONN_MAX_LIFETIME=3600
# DB_CONN_MAX_IDLE_TIME=1800
# DB_CONNECT_TIMEOUT=10
# DB_QUERY_TIMEOUT=30
# DB_LONG_QUERY_TIMEOUT=300

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENV=development # 'development', 'staging', or 'production'
# APP_SECRET_KEY=generate_a_secure_random_string_here

# -----------------------------------------------------------------------------
# JWT & Security Configuration
# -----------------------------------------------------------------------------
# MUST change this to a secure random string (at least 32 characters)
JWT_SECRET=super_secret_jwt_key_that_must_be_changed_before_production
JWT_ISSUER=shiftmaster-api
JWT_ACCESS_EXPIRE_MIN=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# Rate Limiting & Lockout
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MIN=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15
TRUSTED_PROXIES=127.0.0.1

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# -----------------------------------------------------------------------------
# Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_BASE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=pdf,png,jpg,jpeg,doc,docx

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=debug # 'debug', 'info', 'warn', 'error'
LOG_FORMAT=json # 'json' or 'text'
