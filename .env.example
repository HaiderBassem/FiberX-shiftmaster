#
# Example Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment:
#   cp .env.example .env
#
# Module:  shiftmaster-backend
# Stack:   Go 1.26 · Gin · PostgreSQL · Caddy
# =============================================================================

# =============================================================================
# 🗄️  DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# Primary connection parameters for pgx/v5 driver
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=shiftmaster
DB_SSL_MODE=disable

# ── Connection Pool Tuning ───────────────────────────────────────────────────
# Fine-tune pool behavior based on your workload.
# Uncomment and adjust as needed; defaults (shown) are applied if omitted.
#
# DB_MAX_OPEN_CONNS=50          # Maximum simultaneous open connections
# DB_MIN_CONNS=10               # Minimum idle connections kept alive
# DB_CONN_MAX_LIFETIME=3600     # Max lifetime of a connection (seconds)
# DB_CONN_MAX_IDLE_TIME=1800    # Max idle time before closing (seconds)
# DB_CONNECT_TIMEOUT=10         # Dial timeout (seconds)
# DB_QUERY_TIMEOUT=30           # Standard query timeout (seconds)
# DB_LONG_QUERY_TIMEOUT=300     # Long-running query timeout (seconds)
# DB_HEALTH_CHECK_PERIOD=60     # Health-check interval (seconds)
# DB_MAX_RETRIES=3              # Connection retry attempts
# DB_RETRY_INTERVAL_MS=100      # Delay between retries (milliseconds)

# =============================================================================
# 🌐  SERVER CONFIGURATION
# =============================================================================
# The API listens on SERVER_HOST:SERVER_PORT.
# ENV controls behavior: 'development' | 'staging' | 'production'
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENV=development

# ── HTTP Timeouts (seconds) ──────────────────────────────────────────────────
# SERVER_READ_TIMEOUT=60        # Max time to read the full request
# SERVER_WRITE_TIMEOUT=60       # Max time to write the response
# SERVER_IDLE_TIMEOUT=120       # Max keep-alive idle time

# ── App Secret ──
# Required in production. Generate with: openssl rand -hex 32
# APP_SECRET_KEY=generate_a_secure_random_string_here

# =============================================================================
# 🔐  JWT & SECURITY CONFIGURATION
# =============================================================================
# ⚠️  IMPORTANT: Change JWT_SECRET before deploying to production!
# Generate with: openssl rand -hex 32 (must be ≥ 32 characters)
JWT_SECRET=super_secret_jwt_key_that_must_be_changed_before_production
JWT_ISSUER=shiftmaster-api
JWT_ACCESS_EXPIRE_MIN=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# ── Rate Limiting & Account Lockout ──────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MIN=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15

# ── Trusted Proxies ─────────────────────────────────────────────────────────
# Comma-separated IPs or CIDR ranges for reverse proxy trust.
TRUSTED_PROXIES=127.0.0.1

# =============================================================================
# 🔗  CORS CONFIGURATION
# =============================================================================
# For local dev, allow your frontend dev-server origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# =============================================================================
# 📁  UPLOAD CONFIGURATION
# =============================================================================
# Files are stored under UPLOAD_BASE_PATH with sub-directories:
#   ./uploads/assignments/  — Shift assignment documents
#   ./uploads/profiles/     — Employee profile photos
#   ./uploads/documents/    — General documents
UPLOAD_BASE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=pdf,png,jpg,jpeg,doc,docx

# =============================================================================
# 📋  LOGGING CONFIGURATION
# =============================================================================
# LOG_LEVEL  — Verbosity: 'debug' | 'info' | 'warn' | 'error'
# LOG_FORMAT — Output format: 'json' (structured) | 'text' (human-readable)
LOG_LEVEL=debug
LOG_FORMAT=json
